{
    "name": "nikitaarepyev/todo-api-junior-php",
    "description": "REST API для управления задачами на чистом PHP",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "TodoApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TodoApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000 router.php",
        "test": "phpunit"
    }
}
